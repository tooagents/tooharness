{
  "$schema": "https://schema.agentcore.aws.dev/v1/agentcore.json",
  "name": "myharness",
  "version": 1,
  "managedBy": "CDK",
  "tags": {
    "agentcore:created-by": "agentcore-cli",
    "agentcore:project-name": "myharness"
  },
  "runtimes": [
    {
      "name": "TooMcp",
      "build": "CodeZip",
      "entrypoint": "main.py",
      "codeLocation": "app/TooMcp/",
      "runtimeVersion": "PYTHON_3_14",
      "networkMode": "PUBLIC",
      "instrumentation": {
        "enableOtel": false
      },
      "protocol": "MCP",
      "envVars": [
        {
          "name": "FASTAPI_URL",
          "value": "https://t4harness.fastapicloud.dev"
        }
      ]
    }
  ],
  "memories": [
    {
      "name": "TooHarnessMemory",
      "eventExpiryDuration": 365,
      "strategies": [
        {
          "type": "SEMANTIC",
          "namespaceTemplates": [
            "/users/{actorId}/facts"
          ]
        },
        {
          "type": "USER_PREFERENCE",
          "namespaceTemplates": [
            "/users/{actorId}/preferences"
          ]
        }
      ]
    }
  ],
  "knowledgeBases": [],
  "credentials": [],
  "evaluators": [],
  "onlineEvalConfigs": [],
  "agentCoreGateways": [],
  "policyEngines": [],
  "configBundles": [],
  "abTests": [],
  "harnesses": [
    {
      "name": "TooHarness",
      "path": "app/TooHarness"
    }
  ],
  "datasets": [],
  "payments": []
}